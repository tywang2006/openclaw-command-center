# OpenClaw Command Center Configuration
# Copy to .env and modify as needed (requires dotenv or system env vars)

# --- Core ---
OPENCLAW_HOME=~/.openclaw
CMD_PORT=5100
CMD_HOST=127.0.0.1
# CORS_ORIGIN=http://localhost:5100

# --- OpenClaw Gateway ---
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_AUTH_TOKEN=
# OPENCLAW_WORKSPACE=~/.openclaw/workspace

# --- Telegram (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_GROUP_ID=

# --- Debug ---
# GATEWAY_DEBUG=true
